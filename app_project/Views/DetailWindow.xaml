<Window x:Class="app_project.Views.DetailWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Moment Details" Height="720" Width="640" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BFA181"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F5ECD7"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BFA181"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderBrush" Value="#BFA181"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a1a1a"/>
                                <Setter Property="BorderBrush" Value="#D4B896"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <!-- Sjena -->
    <Border Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.7" BlurRadius="24" ShadowDepth="0"/>
        </Border.Effect>
        <!-- Glavni container -->
        <Border Background="#0D0D0D" BorderBrush="#BFA181" BorderThickness="1" CornerRadius="1" MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="3"/>
                </Grid.RowDefinitions>
                <!-- Top zlatna linija -->
                <Rectangle Grid.Row="0" Fill="#BFA181"/>
                <!-- Header -->
                <Grid Grid.Row="1" Margin="24,0">
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="20" Height="1" Fill="#BFA181" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="CHANEL" FontFamily="Georgia" FontSize="16" FontWeight="Bold" Foreground="#BFA181" VerticalAlignment="Center"/>
                            <Rectangle Width="20" Height="1" Fill="#BFA181" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="I C O N I C M O M E N T S" FontFamily="Segoe UI" FontSize="8" Foreground="#555" Margin="30,2,0,0"/>
                    </StackPanel>
                    <!-- Close dugme -->
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Foreground="#555" BorderThickness="0" Cursor="Hand" FontSize="14" Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" Padding="8">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#BFA181"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
                <!-- Tanka zlatna linija ispod headera -->
                <Rectangle Grid.Row="1" Height="1" Fill="#BFA181" Opacity="0.3" VerticalAlignment="Bottom"/>
                <!-- Sadrzaj -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Slika — puna sirina -->
                        <Border Height="240" Background="#111">
                            <Grid>
                                <Image x:Name="MomentImage" Stretch="Uniform"/>
                                <!-- Gradient overlay na dnu slike -->
                                <Rectangle VerticalAlignment="Bottom" Height="130">
                                  
                                </Rectangle>
                            </Grid>
                        </Border>
                        <!-- Title preko slike (overlay efekat) -->
                        <Border Background="#111" Padding="28,20,28,0">
                            <StackPanel>
                                <!-- Dekorativna linija -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Rectangle Width="32" Height="1" Fill="#BFA181" VerticalAlignment="Center"/>
                                    <TextBlock Text=" ✦ " Foreground="#BFA181" FontSize="10" VerticalAlignment="Center"/>
                                    <Rectangle Width="32" Height="1" Fill="#BFA181" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Title -->
                                <TextBlock Text="TITLE" Style="{StaticResource DetailLabel}"/>
                                <TextBlock x:Name="TitleValue" FontFamily="Georgia" FontSize="26" FontWeight="Bold" Foreground="#BFA181" TextWrapping="Wrap" Margin="0,0,0,24"/>
                                <!-- Year i Date -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="YEAR" Style="{StaticResource DetailLabel}"/>
                                        <TextBlock x:Name="YearValue" Style="{StaticResource DetailValue}"/>
                                    </StackPanel>
                                    <!-- Vertikalni separator -->
                                    <Rectangle Grid.Column="1" Width="1" Fill="#BFA181" Opacity="0.2"/>
                                    <StackPanel Grid.Column="2" Margin="16,0,0,0">
                                        <TextBlock Text="DATE ADDED" Style="{StaticResource DetailLabel}"/>
                                        <TextBlock x:Name="DateValue" Style="{StaticResource DetailValue}"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Horizontalni separator -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Rectangle Height="1" Fill="#BFA181" Opacity="0.2" Width="260"/>
                                    <TextBlock Text=" ✦ " Foreground="#BFA181" Opacity="0.4" FontSize="9" VerticalAlignment="Center"/>
                                    <Rectangle Height="1" Fill="#BFA181" Opacity="0.2" Width="260"/>
                                </StackPanel>
                                <!-- Description -->
                                <TextBlock Text="DESCRIPTION" Style="{StaticResource DetailLabel}" Margin="0,0,0,10"/>
                                <RichTextBox x:Name="DescriptionViewer" Background="Transparent" Foreground="#D4C5A9" BorderThickness="0" IsReadOnly="True" FontFamily="Georgia" FontSize="13" Padding="0" IsDocumentEnabled="True" Margin="0,0,0,28"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                <!-- Footer -->
                <Border Grid.Row="3" Background="#0A0A0A" BorderBrush="#BFA181" BorderThickness="0,1,0,0">
                    <Grid Margin="24,0">
                        <TextBlock Text="✦ CHANEL ✦" Foreground="#333" FontFamily="Georgia" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <Button Content="C L O S E" Style="{StaticResource OutlineButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="100" Click="CloseButton_Click"/>
                    </Grid>
                </Border>
                <!-- Dno zlatna linija -->
                <Rectangle Grid.Row="4" Fill="#BFA181"/>

            </Grid>
        </Border>
    </Border>
</Window>