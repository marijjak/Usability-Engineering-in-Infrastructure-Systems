<Window x:Class="app_project.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:app_project.Models"
        Title="Chanel CMS — Iconic Moments"
        Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a">

    <Window.Resources>
        <local:PathToImageConverter x:Key="PathToImageConverter"/>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BFA181"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GoldButton" TargetType="Button">
            <Setter Property="Background" Value="#BFA181"/>
            <Setter Property="Foreground" Value="#1a1a1a"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BFA181"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#b8904a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BFA181"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderBrush" Value="#BFA181"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a2a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid stil -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#f0e6d3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2a2a2a"/>
            <Setter Property="RowBackground" Value="#1a1a1a"/>
            <Setter Property="AlternatingRowBackground" Value="#222222"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
            <Setter Property="RowHeight" Value="70"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#BFA181"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2a2010"/>
                    <Setter Property="Foreground" Value="#f0e6d3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111111"
                BorderBrush="#BFA181" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CHANEL"
                               FontFamily="Georgia" FontSize="22"
                               FontWeight="Bold" Foreground="#BFA181"/>
                    <TextBlock Text="I C O N I C  M O M E N T S"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#888"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserInfoText"
                               FontFamily="Georgia" FontSize="12"
                               Foreground="#888" VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Ellipse Width="8" Height="8" Fill="#BFA181"
                             VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#161616"
                BorderBrush="#2a2a2a" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="SelectAllCheckBox"
                              Content="Select all"
                              Foreground="#888"
                              FontFamily="Georgia"
                              FontSize="12"
                              VerticalAlignment="Center"
                              Checked="SelectAllCheckBox_Checked"
                              Unchecked="SelectAllCheckBox_Unchecked">
                        <CheckBox.ToolTip>
                            <ToolTip Content="Select / deselect all moments"/>
                        </CheckBox.ToolTip>
                    </CheckBox>
                </StackPanel>

                <StackPanel x:Name="AdminButtonsPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="AddButton"
                            Content="+ ADD MOMENT"
                            Style="{StaticResource GoldButton}"
                            Margin="0,0,8,0"
                            Click="AddButton_Click">
                        <Button.ToolTip>
                            <ToolTip Content="Add a new iconic moment"/>
                        </Button.ToolTip>
                    </Button>
                    <Button x:Name="DeleteButton"
                            Content="DELETE"
                            Style="{StaticResource OutlineButton}"
                            Click="DeleteButton_Click">
                        <Button.ToolTip>
                            <ToolTip Content="Delete selected moments"/>
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="MomentsDataGrid"
                  Grid.Row="2"
                  Margin="24,16"
                  ItemsSource="{Binding}">

            <DataGrid.Columns>

                <!-- Kolona 1: CheckBox -->
                <DataGridTemplateColumn Width="50">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="" Style="{StaticResource HeaderText}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected,
                                          RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                      HorizontalAlignment="Center"
                                      Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Kolona 2: Hyperlink (Title) -->
                <DataGridTemplateColumn Header="TITLE" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Hyperlink Foreground="#c9a96e"
                                           Click="TitleHyperlink_Click"
                                           Tag="{Binding}">
                                    <Run Text="{Binding Title}"/>
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Kolona 3: Slika -->
                <DataGridTemplateColumn Header="IMAGE" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Height="60" Width="80"
                   Stretch="UniformToFill"
                   Source="{Binding ImagePath,
                       Converter={StaticResource PathToImageConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Kolona 4: Datum -->
                <DataGridTemplateColumn Header="DATE ADDED" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DateAdded, StringFormat='{}{0:dd MMM yyyy}',
                                       ConverterCulture='en-US'}"
                                       Foreground="#888"
                                       FontFamily="Georgia"
                                       FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Kolona 5: Year -->
                <DataGridTemplateColumn Header="YEAR" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Year}"
                                       Foreground="#888"
                                       FontFamily="Georgia"
                                       FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#111111"
                BorderBrush="#BFA181" BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           Foreground="#555"
                           FontFamily="Georgia"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Button Content="SIGN OUT"
                        Style="{StaticResource OutlineButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="SignOutButton_Click">
                    <Button.ToolTip>
                        <ToolTip Content="Return to login screen"/>
                    </Button.ToolTip>
                </Button>
   
            </Grid>
        </Border>
        <Image Source="pack://application:,,,/Resources/Images/coco.png" 
    Grid.Row="0" 
    Grid.RowSpan="5"
    Width="240" 
    Opacity="0.7" 
    HorizontalAlignment="Right" 
    VerticalAlignment="Bottom" 
    Margin="0,0,10,60" 
    Stretch="Uniform" 
    Panel.ZIndex="10" 
    IsHitTestVisible="False"/>
    </Grid>
</Window>